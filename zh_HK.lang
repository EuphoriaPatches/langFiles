value.DIRECTIONAL_BLOCKLIGHT.11=強烈 §c[-]

option.HELD_LIGHTING_MODE=動態手持光源模式
option.HELD_LIGHTING_MODE.comment=允許手持光源在視覺上點亮周圍場景.
value.HELD_LIGHTING_MODE.0=關
value.HELD_LIGHTING_MODE.1=微弱
value.HELD_LIGHTING_MODE.2=正常

